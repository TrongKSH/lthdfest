    "regionAria": "Frequently asked questions",
    "items": {
      "1": {
        "question": "When is the festival?",
        "answer": "The event runs over two days with two distinct experiences. Gate times and the full schedule will be updated on this website."
      },
      "2": {
        "question": "Where can I buy tickets?",
        "answer": "Tickets are sold officially on the festival website. Buy only from official sources to protect your purchase."
      },
      "3": {
        "question": "How do I receive my tickets after payment?",
        "answer": "E-tickets will be emailed within 48 hours of successful payment. Please check your inbox."
      },
      "4": {
        "question": "What if I don't receive my tickets by email?",
        "answer": "Check spam and other folders. If you still don't see them, contact us via the official fan page or hotline."
      },
      "5": {
        "question": "Can I refund or exchange my tickets?",
        "answer": "Paid tickets are non-refundable and non-exchangeable unless the organizer cancels the event."
      },
      "6": {
        "question": "Is there an age limit?",
        "answer": "The event is intended for ages 16+. Under 16 must attend with a guardian."
      }
    }
  },
